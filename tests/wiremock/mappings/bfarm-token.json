{
  "request": {
    "method": "POST",
    "urlPattern": ".*/token.*"
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "access_token": "mock-bfarm-token",
      "token_type": "Bearer",
