# DNPM/DIP Integration Test - Environment Variables
# Copy this to .env and adjust as needed.

# Image tags (default: latest)
#BACKEND_IMAGE_TAG=latest
#CCDN_IMAGE_TAG=latest

# Pull policy: "always" forces re-pull, "if_not_present" uses cached image
PULL_POLICY=if_not_present

# Exposed ports for DIP node REST APIs
NODE1_PORT=8001
NODE2_PORT=8002

# Secrets (change if needed)
AUTHUP_SECRET=start123
MYSQL_ROOT_PASSWORD=start123

# Random test data: number of patients to generate per node (positive int)
MTB_RANDOM_DATA=50
RD_RANDOM_DATA=50

# BfArM credentials (optional: only needed for full end-to-end test with BfArM submission)
# Without valid credentials the CCDN will log BfArM errors but still polls DIP nodes.
#BFARM_CLIENT_ID=your-client-id
#BFARM_CLIENT_SECRET=your-client-secret
#BFARM_API_URL=https://mvgenomseq.bfarm.de/api/upload
#BFARM_AUTH_URL=https://mvgenomseq.bfarm.de/realms/mvgenomseq/protocol/openid-connect/token
